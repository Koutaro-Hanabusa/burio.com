# Development Environment Variables
# Copy this file to .dev.vars and fill in your actual values
# IMPORTANT: Never commit .dev.vars to git!

# Authentication Secret (generate a random string)
BETTER_AUTH_SECRET=your-dev-secret-here

# Admin token signing key (random string, 32+ bytes recommended)
# Production: set via dashboard or `wrangler versions secret put ADMIN_TOKEN_SECRET`
ADMIN_TOKEN_SECRET=your-admin-token-secret-here

# Comma-separated IPs allowed to access the admin panel
ADMIN_ALLOWED_IPS=127.0.0.1,::1

# Cloudflare Account ID (optional for local dev)
# CLOUDFLARE_ACCOUNT_ID=

# D1 Database Configuration (optional for local dev)
# These are automatically handled by wrangler.toml bindings
# CLOUDFLARE_DATABASE_ID=
# CLOUDFLARE_D1_TOKEN=

# Additional secrets can be added here as needed
# Example: GITHUB_TOKEN=
# Example: STRIPE_SECRET_KEY=
